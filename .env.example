# Copy to .env.local for local dev. Add the same names in Vercel → Settings → Environment Variables.

# === REQUIRED (Supabase) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# === REQUIRED (encrypt CF cookies in database) ===
CF_SESSION_SECRET=run: openssl rand -hex 32

# === REQUIRED for diagnosis on Vercel (cannot use local Ollama) ===
# Sign up: https://api.together.ai — free credits
OLLAMA_MODE=together
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# === REQUIRED for practice-problem tab ===
GROQ_API_KEY=gsk_...

# === LOCAL DEV ONLY (use these instead of Together on your Mac) ===
# OLLAMA_MODE=local
# OLLAMA_LOCAL_URL=http://localhost:11434
# OLLAMA_MODEL=codellama:7b

# === OPTIONAL: remote Ollama on Fly.io instead of Together ===
# OLLAMA_MODE=remote
# OLLAMA_REMOTE_URL=https://your-app.fly.dev
# OLLAMA_API_KEY=
